{
  "requirements": {
    "allowedApprovalPolicies": ["never", "on-request"],
    "allowedApprovalsReviewers": ["user", "auto_review"],
    "allowedSandboxModes": ["read-only", "workspace-write"],
    "allowedPermissions": [":read-only", "managed"],
    "allowedWebSearchModes": ["disabled", "cached", "live"],
    "featureRequirements": {
      "apps": true,
      "network": false,
      "ignoreMe": "not-a-bool"
    },
    "allowManagedHooksOnly": true,
    "allowAppshots": false,
    "computerUse": {
      "allowLockedComputerUse": true
    },
    "hooks": {
      "managedDir": ".codex/hooks"
    },
    "enforceResidency": "us",
    "network": {
      "enabled": true,
      "httpPort": 8080,
      "socksPort": 1080,
      "allowUpstreamProxy": false,
      "dangerouslyAllowNonLoopbackProxy": false,
      "dangerouslyAllowNonLoopbackAdmin": false,
      "allowedDomains": ["example.com"],
      "deniedDomains": ["bad.example"],
      "allowUnixSockets": ["/var/run/docker.sock"],
      "allowLocalBinding": true,
      "unknownField": "preserve"
    },
    "unknownTopLevelField": true
  }
}
